#!/data/data/com.termux/files/usr/bin/bash

# 1. Force Ravi Dwivedi's mirror (Non-interactive)
export TERMUX_PKG_NO_MIRROR_SELECT=https://mirrors.ravidwivedi.in/termux/
echo "Switching repository to Ravi Dwivedi's mirror..."
echo "deb https://mirrors.ravidwivedi.in/termux/termux-main stable main" > /data/data/com.termux/files/usr/etc/apt/sources.list

# 2. Update with mirror check
pkg update -y
pkg upgrade -y

# 3. Install core packages + GitHub CLI (gh)
pkg i neovim clang libllvm python3 nodejs curl wget ncurses-utils \
lazygit git tree-sitter lua-language-server luarocks ripgrep fd \
stylua gh -y

# 4. Interactive Git & GitHub Setup
echo "--- Git & GitHub Configuration ---"
read -p "Enter your Git User Name: " GIT_NAME
read -p "Enter your Git Email: " GIT_EMAIL
# -s hides the token while you type/paste it for security
read -s -p "Enter your GitHub Personal Access Token (PAT): " GIT_TOKEN
echo -e "\n"

# Set Git Configs
git config --global user.name "$GIT_NAME"
git config --global user.email "$GIT_EMAIL"
git config --global credential.helper store

# Authenticate with GitHub using the token
echo "Authenticating with GitHub..."
echo "$GIT_TOKEN" | gh auth login --with-token

# 5. Nerd Font Installation
curl -fsSL https://raw.githubusercontent.com/arnavgr/termux-nf/main/install.sh | bash

# 6. Clone Neovim Dotfiles
if [ -d "$HOME/.config/nvim" ]; then
    echo "Backing up existing nvim config..."
    mv ~/.config/nvim ~/.config/nvim.bak
fi

echo "Cloning Neovim config..."
git clone https://github.com/IamShivanshCoder/nvim-dotfiles.git ~/.config/nvim

echo "--- Setup Complete! ---"
echo "Note: Run 'getnf' to set your font, then restart Termux."
